	</xs:simpleType>
	<xs:simpleType name="M2">
		<xs:restriction base="xs:nonNegativeInteger"/>
	</xs:simpleType>
	<xs:simpleType name="M">
		<xs:restriction base="xs:decimal">
			<xs:minInclusive value="0"/>
			<xs:fractionDigits value="2"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="JN">
		<xs:restriction base="xs:boolean"/>
	</xs:simpleType>
	<xs:simpleType name="Jahr">
		<xs:restriction base="xs:gYear"/>
	</xs:simpleType>
	<xs:simpleType name="Obstjahr">
		<xs:restriction base="xs:gYear">
			<xs:minInclusive value="1960"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="Datum">
		<xs:restriction base="xs:date"/>
	</xs:simpleType>
	<xs:simpleType name="Erstelldatum">
		<xs:restriction base="xs:dateTime"/>
	</xs:simpleType>
	<xs:simpleType name="Tage">
		<xs:restriction base="xs:nonNegativeInteger"/>
	</xs:simpleType>

	<!-- placeholder so that we can validate -->
	<xs:complexType name="localUnitIdentifier">
	</xs:complexType>

</xs:schema>
