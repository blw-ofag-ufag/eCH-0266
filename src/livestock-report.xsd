<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xmlns:eCH_0266="http://www.admin.ch/xmlns/DataTypes/evd/structure/2"
	targetNamespace="http://www.admin.ch/xmlns/DataTypes/evd/structure/2"
	elementFormDefault="qualified" attributeFormDefault="unqualified" version="2023-01">


	<!-- This is a portion of the eCH-0266 proposal. Once
		incorporated into that this file can be deleted. -->
	<xs:complexType name="livestockReportType">
		<xs:annotation>
			<xs:documentation xml:lang="de"> </xs:documentation>
			<xs:documentation xml:lang="en"> This defines the animal stock per location and
				reporting source on year-round farms. The report is for the previous
				year vis-à-vis the report date.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="livestock" maxOccurs="unbounded">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="surveyYear" type="xs:gYear">
							<xs:annotation>
								<xs:documentation xml:lang="de"> Enthält das Jahr, in welche die
									Daten erhoben wurden. </xs:documentation>
								<xs:documentation xml:lang="en"> The year for which the data is
									reported. In practice this will be the year previous to that of
									the report date. </xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="reportDate" type="xs:date">
							<xs:annotation>
								<xs:documentation xml:lang="de"> Enthält das Datum des Berichts bzw.
									der Datenübertragung. </xs:documentation>
								<xs:documentation xml:lang="en"> The date on which the report was
									created or data transmission effected. </xs:documentation>
							</xs:annotation>
						</xs:element>
						<!-- change data type before publishing and refer to proper eCH standard -->
						<xs:element name="mainLocalUnit" type="eCH_0266:localUnitIdentifier"/>
						<!-- change data type before publishing and refer to proper eCH standard -->
						<xs:element name="subordinateLocalUnit" type="eCH_0266:localUnitIdentifier"/>
						<xs:element name="animalCategory" type="eCH_0266:animalCategoryType"/>
						<xs:choice>
							<xs:element name="livestockAnimalTracing"
								type="eCH_0266:livestockReportedViaAnimalTracingType"/>
							<xs:element name="livestockSelfDeclared"
										type="eCH_0266:selfReportedLivestockType" maxOccurs="unbounded"
							/>
						</xs:choice>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="livestockReportedViaAnimalTracingType">
		<xs:sequence>
			<xs:element name="atdDataOriginal"
				type="eCH_0266:livestockReportedViaAnimalTracingOriginalType"/>
			<xs:element name="atdDataFinal"
				type="eCH_0266:livestockReportedViaAnimalTracingFinalType"/>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="livestockReportedViaAnimalTracingOriginalType">
		<xs:sequence>
			<xs:element name="quantityTotal" type="eCH_0266:QuantityDecimal"/>
			<xs:element name="livestockUnitTotal" type="eCH_0266:GVE"/>
			<xs:element name="durationSumTotal" type="eCH_0266:Tage"/>
			<xs:element name="surveyFarmDetails">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="declarationDayQuantity" type="xs:nonNegativeInteger"/>
						<xs:element name="quantity" type="eCH_0266:QuantityDecimal"/>
						<xs:element name="livestockUnit" type="eCH_0266:GVE"/>
						<xs:element name="durationSum" type="eCH_0266:Tage"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="summeringInlandDetails" minOccurs="0">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="livestockUnit" type="eCH_0266:GVE"/>
						<xs:element name="normedLivestockUnit" type="eCH_0266:NST"/>
						<xs:element name="durationSum" type="eCH_0266:Tage"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="summeringAbroadDetails" minOccurs="0">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="livestockUnit" type="eCH_0266:GVE"/>
						<xs:element name="durationSum" type="eCH_0266:Tage"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="livestockReportedViaAnimalTracingFinalType">
		<xs:sequence>
			<xs:element name="quantityTotal" type="eCH_0266:QuantityDecimal"/>
			<xs:element name="livestockUnitTotal" type="eCH_0266:GVE"/>
			<xs:element name="surveyFarmDetails">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="declarationDayQuantity" type="xs:nonNegativeInteger"/>
						<xs:element name="quantity" type="eCH_0266:QuantityDecimal"/>
						<xs:element name="livestockUnit" type="eCH_0266:GVE"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="summeringInlandDetails" minOccurs="0">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="livestockUnit" type="eCH_0266:GVE"/>
						<xs:element name="normedLivestockUnit" type="eCH_0266:NST"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="summeringAbroadDetails" minOccurs="0">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="livestockUnit" type="eCH_0266:GVE"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="selfReportedLivestockType">
		<xs:sequence>
			<xs:element name="declarationDayQuantity" type="xs:nonNegativeInteger"/>
			<xs:element name="averageQuantity" type="xs:nonNegativeInteger"/>
			<xs:element name="keepingType" type="eCH_0266:animalKeepingType" minOccurs="0"/>
			<xs:element name="summeringQuantity" type="xs:nonNegativeInteger"/>
			<xs:element name="summeringDuration" type="xs:gDay"> </xs:element>
		</xs:sequence>
	</xs:complexType>


	<!-- ANIMAL SUMMERING DATA -->

	<xs:complexType name="animalSummeringDataType">
		<xs:sequence>
			<xs:element name="animalStock" maxOccurs="unbounded">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="creationDate" type="eCH_0266:Erstelldatum"/>
						<xs:element name="localFarmId" type="eCH_0266:localUnitIdentifier"/>
						<xs:element name="localPersonId" type="eCH_0266:personIdType"/>
						<xs:element name="animalCategory" type="eCH_0266:animalCategoryType"/>
						<xs:choice>
							<xs:element name="atdData" type="eCH_0266:atdSummeringDataType"/>
							<xs:element name="selfreportedData"
								type="eCH_0266:selfReportedLivestockType"
								maxOccurs="unbounded"/>
						</xs:choice>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="atdSummeringDataType">
		<xs:sequence>
			<xs:element name="atdDataOriginal"
				type="eCH_0266:animalTracingSummeringDataOriginalType"/>
			<xs:element name="atdDataFinal" type="eCH_0266:animalTracingSummeringDataFinalType"
			/>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="animalTracingSummeringDataOriginalType">
		<xs:sequence>
			<xs:element name="declarationDayQuantity" type="xs:nonNegativeInteger"/>
			<xs:element name="quantityTotal" type="eCH_0266:QuantityDecimal"/>
			<xs:element name="livestockUnit" type="eCH_0266:GVE"/>
			<xs:element name="normedLivestockUnit" type="eCH_0266:NST"/>
			<xs:element name="durationSum" type="eCH_0266:Tage"/>
			<xs:element name="averageAnimalDurationSum" type="eCH_0266:Tage"/>
			<xs:element name="quantitySumNotTerminated" type="xs:nonNegativeInteger"/>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="animalTracingSummeringDataFinalType">
		<xs:sequence>
			<xs:element name="quantityTotal" type="eCH_0266:QuantityDecimal"/>
			<xs:element name="livestockUnit" type="eCH_0266:GVE"/>
			<xs:element name="normedLivestockUnit" type="eCH_0266:NST"/>
			<xs:element name="averageAnimalDurationSum" type="eCH_0266:Tage"/>
		</xs:sequence>
	</xs:complexType>

	<xs:simpleType name="summeringTypeType">
		<xs:restriction base="xs:token">
			<xs:enumeration value="0"/>
			<xs:enumeration value="1"/>
			<xs:enumeration value="2"/>
			<xs:enumeration value="3"/>
		</xs:restriction>
	</xs:simpleType>


